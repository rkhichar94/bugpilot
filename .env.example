# Jira (via Atlassian Remote MCP Server — https://mcp.atlassian.com/v1/mcp)
ATLASSIAN_MCP_TOKEN=your_atlassian_oauth_access_token
JIRA_PROJECT_KEY=PROJ
JIRA_JQL_FILTER=issuetype=Bug AND status=Open AND priority=High

# GitHub
GITHUB_TOKEN=ghp_your_token_here
REPO_URL=https://github.com/yourusername/your-spring-boot-repo
REPO_DEFAULT_BRANCH=main

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Qdrant (run locally: docker run -p 6333:6333 qdrant/qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=bug_issues

# LangSmith (optional but recommended for tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# Slack (optional — sends a message with PR link when fix is ready)
SLACK_WEBHOOK_URL=
